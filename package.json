{
  "name": "arcana",
  "version": "0.0.0",
  "description": "Interactive tarot-style mini-app built with Angular, SSR, and SCSS.",
  "author": "Alexandr Gurin",
  "license": "MIT",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24.11.0 <25",
    "npm": ">=11 <12"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox",
    "serve:ssr": "npm run serve:ssr:arcana",
    "serve:ssr:arcana": "node dist/arcana/server/server.mjs",
    "eslint": "eslint .",
    "eslint:fix": "eslint . --fix",
    "lint:eslint": "eslint . --max-warnings=0",
    "stylelint": "stylelint \"src/**/*.{scss,css}\"",
    "stylelint:fix": "stylelint \"src/**/*.{scss,css}\" --fix",
    "lint:styles": "stylelint \"src/**/*.{scss,css}\" --max-warnings=0",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "lint-all": "npm run lint:eslint && npm run lint:styles && npm run format:check",
    "verify": "npm run lint-all && npm run test:ci && npm run build",
    "prepare": "husky",
    "lint-staged": "lint-staged"
  },
  "lint-staged": {
    "**/*.ts": [
      "eslint --fix --max-warnings=0"
    ],
    "**/*.{scss,css}": [
      "stylelint --fix"
    ],
    "**/*.{md,json,yml,yaml,html}": [
      "prettier -w"
    ]
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.12",
    "@angular/compiler": "^21.2.12",
    "@angular/core": "^21.2.12",
    "@angular/forms": "^21.2.12",
    "@angular/platform-browser": "^21.2.12",
    "@angular/platform-server": "^21.2.12",
    "@angular/router": "^21.2.12",
    "@angular/ssr": "^21.2.10",
    "express": "^5.2.1",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/eslint-plugin": "^21.3.1",
    "@angular-eslint/eslint-plugin-template": "^21.3.1",
    "@angular-eslint/template-parser": "^21.3.1",
    "@angular/build": "^21.2.10",
    "@angular/cli": "^21.2.10",
    "@angular/compiler-cli": "^21.2.12",
    "@types/express": "^5.0.6",
    "@types/jasmine": "~6.0.0",
    "@types/node": "^24.12.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jasmine-core": "~6.2.0",
    "karma": "~6.4.4",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.1",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.2.0",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "stylelint": "^17.11.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.59.2"
  }
}
